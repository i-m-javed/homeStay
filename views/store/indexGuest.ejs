<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { pageTitle: 'Welcome Guest' }) %>
  <body class="bg-gray-50 text-gray-800 font-sans">
    <div class="min-h-screen flex flex-col">
      <%- include('../partials/nav', { user }) %>

      <!-- Hero / Guest Greeting Section -->
      <section
        class="relative bg-gradient-to-br from-white via-red-50 to-white py-24 md:py-32 text-center overflow-hidden"
      >
        <!-- Decorative background blobs -->
        <div
          class="absolute top-0 left-0 w-72 h-72 bg-red-100 rounded-full opacity-30 -translate-x-1/2 -translate-y-1/2 blur-3xl"
        ></div>
        <div
          class="absolute bottom-0 right-0 w-96 h-96 bg-red-100 rounded-full opacity-20 translate-x-1/3 translate-y-1/3 blur-3xl"
        ></div>
        <div
          class="absolute top-1/2 right-10 w-48 h-48 bg-red-200 rounded-full opacity-10 blur-2xl"
        ></div>

        <div class="max-w-5xl mx-auto px-6 z-10 relative">
          <!-- Welcome Badge -->
          <div
            class="inline-flex items-center gap-2 bg-red-100 text-red-600 text-sm font-semibold px-4 py-1.5 rounded-full mb-8 tracking-wide"
          >
            <span class="relative flex h-2.5 w-2.5">
              <span
                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"
              ></span>
              <span
                class="relative inline-flex rounded-full h-2.5 w-2.5 bg-red-500"
              ></span>
            </span>
            You're logged in
          </div>

          <!-- Greeting -->
          <h1
            class="text-5xl md:text-7xl font-extrabold text-gray-900 mb-6 leading-tight"
          >
            Welcome back,
            <span class="relative inline-block mt-2">
              <span
                class="bg-red-500 text-white px-6 py-2 rounded-3xl inline-block shadow-lg"
              >
                <%= user.lastName %>!
              </span>
            </span>
          </h1>

          <p
            class="text-xl md:text-2xl text-gray-500 mb-10 max-w-2xl mx-auto leading-relaxed"
          >
            Ready for your next adventure? Your perfect stay is just a few
            clicks away.
          </p>

          <!-- CTA Buttons -->
          <div
            class="flex flex-col sm:flex-row items-center justify-center gap-4"
          >
            <a
              href="/home"
              class="group bg-red-500 text-white font-semibold px-8 py-4 rounded-full shadow-lg hover:bg-red-600 hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 flex items-center gap-2"
            >
              Explore Listings
              <svg
                class="w-5 h-5 group-hover:translate-x-1 transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"
                />
              </svg>
            </a>
            <a
              href="/listings/new"
              class="text-gray-600 font-semibold px-8 py-4 rounded-full border-2 border-gray-200 hover:border-red-300 hover:text-red-500 transition-all duration-300 flex items-center gap-2"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 4v16m8-8H4"
                />
              </svg>
              List Your Property
            </a>
          </div>

          <!-- Quick Stats / Highlights -->
          <div
            class="mt-14 flex flex-col sm:flex-row items-center justify-center gap-8 text-sm"
          >
            <div class="flex items-center gap-2 text-gray-500">
              <div
                class="w-8 h-8 bg-red-100 rounded-full flex items-center justify-center"
              >
                <svg
                  class="w-4 h-4 text-red-500"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                  />
                </svg>
              </div>
              <span
                ><span class="font-semibold text-gray-700">10K+</span> listings
                available</span
              >
            </div>
            <div class="hidden sm:block w-1 h-1 bg-gray-300 rounded-full"></div>
            <div class="flex items-center gap-2 text-gray-500">
              <div
                class="w-8 h-8 bg-red-100 rounded-full flex items-center justify-center"
              >
                <svg
                  class="w-4 h-4 text-red-500"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    fill-rule="evenodd"
                    d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"
                    clip-rule="evenodd"
                  />
                </svg>
              </div>
              <span
                ><span class="font-semibold text-gray-700">120+</span>
                countries</span
              >
            </div>
            <div class="hidden sm:block w-1 h-1 bg-gray-300 rounded-full"></div>
            <div class="flex items-center gap-2 text-gray-500">
              <div
                class="w-8 h-8 bg-red-100 rounded-full flex items-center justify-center"
              >
                <svg
                  class="w-4 h-4 text-red-500"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd"
                  />
                </svg>
              </div>
              <span
                ><span class="font-semibold text-gray-700">Instant</span>
                booking</span
              >
            </div>
          </div>
        </div>

        <div class="mt-24"><%- include('../partials/features') %></div>
      </section>

      <!-- Quick Browse by Category -->
      <section class="bg-white py-20">
        <div class="max-w-6xl mx-auto px-6">
          <div class="text-center mb-12">
            <span
              class="inline-block bg-red-100 text-red-600 text-xs font-bold px-3 py-1 rounded-full mb-4 uppercase tracking-widest"
              >Explore</span
            >
            <h2 class="text-3xl md:text-4xl font-extrabold text-gray-800 mb-3">
              Where Do You Want to Go?
            </h2>
            <p class="text-gray-500 text-lg max-w-xl mx-auto">
              Pick a vibe and let's find your perfect stay.
            </p>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-5">
            <a
              href="/home?category=beachfront"
              class="group bg-gradient-to-b from-white to-gray-50 rounded-2xl p-6 text-center shadow-md hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 cursor-pointer border border-gray-100 hover:border-red-200 no-underline"
            >
              <div
                class="text-5xl mb-3 group-hover:scale-110 transition-transform duration-300"
              >
                🏖️
              </div>
              <p
                class="font-semibold text-gray-700 group-hover:text-red-500 transition-colors"
              >
                Beachfront
              </p>
              <p class="text-xs text-gray-400 mt-1">2.4K stays</p>
            </a>
            <a
              href="/home?category=mountain"
              class="group bg-gradient-to-b from-white to-gray-50 rounded-2xl p-6 text-center shadow-md hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 cursor-pointer border border-gray-100 hover:border-red-200 no-underline"
            >
              <div
                class="text-5xl mb-3 group-hover:scale-110 transition-transform duration-300"
              >
                🏔️
              </div>
              <p
                class="font-semibold text-gray-700 group-hover:text-red-500 transition-colors"
              >
                Mountain
              </p>
              <p class="text-xs text-gray-400 mt-1">1.8K stays</p>
            </a>
            <a
              href="/home?category=countryside"
              class="group bg-gradient-to-b from-white to-gray-50 rounded-2xl p-6 text-center shadow-md hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 cursor-pointer border border-gray-100 hover:border-red-200 no-underline"
            >
              <div
                class="text-5xl mb-3 group-hover:scale-110 transition-transform duration-300"
              >
                🏡
              </div>
              <p
                class="font-semibold text-gray-700 group-hover:text-red-500 transition-colors"
              >
                Countryside
              </p>
              <p class="text-xs text-gray-400 mt-1">1.2K stays</p>
            </a>
            <a
              href="/home?category=castle"
              class="group bg-gradient-to-b from-white to-gray-50 rounded-2xl p-6 text-center shadow-md hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 cursor-pointer border border-gray-100 hover:border-red-200 no-underline"
            >
              <div
                class="text-5xl mb-3 group-hover:scale-110 transition-transform duration-300"
              >
                🏰
              </div>
              <p
                class="font-semibold text-gray-700 group-hover:text-red-500 transition-colors"
              >
                Castles
              </p>
              <p class="text-xs text-gray-400 mt-1">340 stays</p>
            </a>
            <a
              href="/home?category=treehouse"
              class="group bg-gradient-to-b from-white to-gray-50 rounded-2xl p-6 text-center shadow-md hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 cursor-pointer border border-gray-100 hover:border-red-200 no-underline"
            >
              <div
                class="text-5xl mb-3 group-hover:scale-110 transition-transform duration-300"
              >
                🌲
              </div>
              <p
                class="font-semibold text-gray-700 group-hover:text-red-500 transition-colors"
              >
                Treehouses
              </p>
              <p class="text-xs text-gray-400 mt-1">560 stays</p>
            </a>
            <a
              href="/home?category=city"
              class="group bg-gradient-to-b from-white to-gray-50 rounded-2xl p-6 text-center shadow-md hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 cursor-pointer border border-gray-100 hover:border-red-200 no-underline"
            >
              <div
                class="text-5xl mb-3 group-hover:scale-110 transition-transform duration-300"
              >
                🏙️
              </div>
              <p
                class="font-semibold text-gray-700 group-hover:text-red-500 transition-colors"
              >
                City Life
              </p>
              <p class="text-xs text-gray-400 mt-1">3.6K stays</p>
            </a>
          </div>
        </div>
      </section>

      <!-- Popular Destinations Section -->
      <section class="bg-gray-50 py-20">
        <div class="max-w-6xl mx-auto px-6">
          <div class="text-center mb-14">
            <span
              class="inline-block bg-red-100 text-red-600 text-xs font-bold px-3 py-1 rounded-full mb-4 uppercase tracking-widest"
              >Trending Now</span
            >
            <h2 class="text-3xl md:text-4xl font-extrabold text-gray-800 mb-3">
              Popular Destinations
            </h2>
            <p class="text-gray-500 text-lg max-w-2xl mx-auto">
              Explore trending locations loved by travelers just like you.
            </p>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            <div
              class="group relative rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 cursor-pointer"
            >
              <img
                src="https://images.unsplash.com/photo-1502602898657-3e91760cbb34?w=600&q=80"
                alt="Paris"
                class="w-full h-64 object-cover group-hover:scale-110 transition-transform duration-700"
              />
              <div
                class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"
              ></div>
              <div
                class="absolute top-4 right-4 bg-white/90 backdrop-blur-sm text-red-500 text-xs font-bold px-3 py-1 rounded-full"
              >
                🔥 Popular
              </div>
              <div class="absolute bottom-0 left-0 p-6">
                <h3 class="text-white text-xl font-bold">Paris, France</h3>
                <p class="text-gray-300 text-sm mt-1">1,200+ stays available</p>
              </div>
            </div>
            <div
              class="group relative rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 cursor-pointer"
            >
              <img
                src="https://images.unsplash.com/photo-1540959733332-eab4deabeeaf?w=600&q=80"
                alt="Tokyo"
                class="w-full h-64 object-cover group-hover:scale-110 transition-transform duration-700"
              />
              <div
                class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"
              ></div>
              <div
                class="absolute top-4 right-4 bg-white/90 backdrop-blur-sm text-red-500 text-xs font-bold px-3 py-1 rounded-full"
              >
                ✨ Trending
              </div>
              <div class="absolute bottom-0 left-0 p-6">
                <h3 class="text-white text-xl font-bold">Tokyo, Japan</h3>
                <p class="text-gray-300 text-sm mt-1">800+ stays available</p>
              </div>
            </div>
            <div
              class="group relative rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 cursor-pointer"
            >
              <img
                src="https://images.unsplash.com/photo-1537996194471-e657df975ab4?w=600&q=80"
                alt="Bali"
                class="w-full h-64 object-cover group-hover:scale-110 transition-transform duration-700"
              />
              <div
                class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"
              ></div>
              <div
                class="absolute top-4 right-4 bg-white/90 backdrop-blur-sm text-red-500 text-xs font-bold px-3 py-1 rounded-full"
              >
                🌴 Paradise
              </div>
              <div class="absolute bottom-0 left-0 p-6">
                <h3 class="text-white text-xl font-bold">Bali, Indonesia</h3>
                <p class="text-gray-300 text-sm mt-1">950+ stays available</p>
              </div>
            </div>
          </div>
          <div class="text-center mt-10">
            <a
              href="/home"
              class="inline-flex items-center gap-2 text-red-500 font-semibold hover:text-red-600 transition group"
            >
              View all destinations
              <svg
                class="w-5 h-5 group-hover:translate-x-1 transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"
                />
              </svg>
            </a>
          </div>
        </div>
      </section>

      <!-- Personalized Banner -->
      <section class="bg-white py-16">
        <div class="max-w-6xl mx-auto px-6">
          <div
            class="bg-gradient-to-r from-red-500 to-red-600 rounded-3xl p-10 md:p-14 flex flex-col md:flex-row items-center justify-between gap-8 shadow-2xl overflow-hidden relative"
          >
            <!-- Decorative circles -->
            <div
              class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full translate-x-1/3 -translate-y-1/3"
            ></div>
            <div
              class="absolute bottom-0 left-1/4 w-40 h-40 bg-white/5 rounded-full translate-y-1/2"
            ></div>

            <div class="relative z-10 text-center md:text-left">
              <span
                class="inline-block bg-white/20 text-white text-xs font-bold px-3 py-1 rounded-full mb-4 uppercase tracking-widest"
                >Exclusive for You</span
              >
              <h2 class="text-2xl md:text-4xl font-extrabold text-white mb-3">
                Hey <%= user.lastName %>, got a place to share?
              </h2>
              <p class="text-red-100 text-lg max-w-lg">
                Earn extra income by listing your space. Thousands of travelers
                are looking for unique stays every day.
              </p>
            </div>
            <div
              class="relative z-10 flex flex-col items-center gap-3 flex-shrink-0"
            >
              <a
                href="/listings/new"
                class="bg-white text-red-500 font-bold px-8 py-4 rounded-full shadow-lg hover:bg-gray-50 hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 whitespace-nowrap"
              >
                Start Hosting Today →
              </a>
              <p class="text-red-200 text-sm">Free to list · No setup fees</p>
            </div>
          </div>
        </div>
      </section>

      <!-- How it Works Section -->
      <%- include('../partials/howItWork') %>

      <!-- Become a Host Section -->
      <%- include('../partials/becomeHost') %>

      <!-- Travel Tips Section -->
      <section class="bg-gray-50 py-20">
        <div class="max-w-6xl mx-auto px-6">
          <div class="text-center mb-14">
            <span
              class="inline-block bg-red-100 text-red-600 text-xs font-bold px-3 py-1 rounded-full mb-4 uppercase tracking-widest"
              >Travel Smarter</span
            >
            <h2 class="text-3xl md:text-4xl font-extrabold text-gray-800 mb-3">
              Tips for a Great Stay
            </h2>
            <p class="text-gray-500 text-lg max-w-2xl mx-auto">
              Make the most of every trip with these quick tips.
            </p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div
              class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-gray-100"
            >
              <div
                class="w-14 h-14 bg-red-100 rounded-2xl flex items-center justify-center text-3xl mb-5"
              >
                📅
              </div>
              <h3 class="text-xl font-bold text-gray-800 mb-3">Book Early</h3>
              <p class="text-gray-500 leading-relaxed">
                The best listings get booked fast. Secure your stay early to get
                the best prices and most options.
              </p>
            </div>
            <div
              class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-gray-100"
            >
              <div
                class="w-14 h-14 bg-red-100 rounded-2xl flex items-center justify-center text-3xl mb-5"
              >
                💬
              </div>
              <h3 class="text-xl font-bold text-gray-800 mb-3">
                Talk to Your Host
              </h3>
              <p class="text-gray-500 leading-relaxed">
                Reach out before you arrive. Hosts love guests who communicate —
                they'll often go the extra mile for you.
              </p>
            </div>
            <div
              class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-gray-100"
            >
              <div
                class="w-14 h-14 bg-red-100 rounded-2xl flex items-center justify-center text-3xl mb-5"
              >
                ⭐
              </div>
              <h3 class="text-xl font-bold text-gray-800 mb-3">
                Leave a Review
              </h3>
              <p class="text-gray-500 leading-relaxed">
                Your reviews help other travelers make great choices. Be honest,
                be kind, and share your experience.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Made By Section -->
      <%- include('../partials/madeBy') %>

      <!-- Footer -->
      <%- include('../partials/footer') %>
    </div>
  </body>
</html>
