        <div
          class="absolute bottom-0 right-0 w-96 h-96 bg-red-100 rounded-full opacity-20 translate-x-1/3 translate-y-1/3 blur-3xl"
        ></div>
        <div
          class="absolute top-1/2 left-1/2 w-64 h-64 bg-red-200 rounded-full opacity-10 -translate-x-1/2 -translate-y-1/2 blur-2xl"
