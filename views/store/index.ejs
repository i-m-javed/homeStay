                class="w-5 h-5 group-hover:translate-x-1 transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"
                />
              </svg>
            </a>
            <a
              href="/login"
              class="text-gray-600 font-semibold px-8 py-4 rounded-full border-2 border-gray-200 hover:border-red-300 hover:text-red-500 transition-all duration-300"
            >
              Already have an account?
            </a>
