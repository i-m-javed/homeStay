<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { pageTitle: 'Welcome to HomeStay' }) %>

  <body class="bg-gray-50 text-gray-800 font-sans">
    <%- include('../partials/nav') %>

    <div class="min-h-screen flex flex-col">
      <!-- Hero Section -->
      <section
        class="relative bg-gradient-to-br from-white via-red-50 to-white py-16 md:py-18 text-center overflow-hidden"
