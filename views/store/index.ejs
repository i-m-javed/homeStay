                class="absolute -bottom-2 left-0 w-full"
                viewBox="0 0 200 12"
                fill="none"
              >
                <path
                  d="M2 8C30 3 70 2 100 5C130 8 170 4 198 7"
                  stroke="#ef4444"
                  stroke-width="3"
                  stroke-linecap="round"
                  opacity="0.4"
